# ── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → project → Settings → Database
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Supabase (Storage + Realtime) ──────────────────────────────────────────
# Get these from: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# ── NextAuth ──────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Vital Sign · Ops"
NEXT_PUBLIC_APP_ORG="Hospital Supplies · PH"

# ── Branding (used across UI and all printed documents) ───────────────────
NEXT_PUBLIC_ORG_NAME="MediSupply PH"
NEXT_PUBLIC_ORG_TAGLINE="Medical Equipment & Supplies"
NEXT_PUBLIC_ORG_ADDRESS="3F Greenfield Tower, Mandaluyong City, Metro Manila 1550"
NEXT_PUBLIC_ORG_PHONE="+63 2 8123 4567"
NEXT_PUBLIC_ORG_EMAIL="info@medisupply.ph"
NEXT_PUBLIC_ORG_TIN="123-456-789-000"
NEXT_PUBLIC_ORG_WEBSITE="www.medisupply.ph"
NEXT_PUBLIC_ORG_COLOR="#003087"
NEXT_PUBLIC_ORG_RDO="044"
NEXT_PUBLIC_ORG_ZIP="1550"
