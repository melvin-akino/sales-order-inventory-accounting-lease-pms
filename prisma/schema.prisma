generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  AGENT
  FINANCE
  WAREHOUSE
  TECHNICIAN
  DRIVER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(AGENT)
  customerId   String?
  technicianId String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer     Customer?    @relation(fields: [customerId],   references: [id])
  technician   Technician?  @relation(fields: [technicianId], references: [id])
  ordersPlaced Order[]      @relation("PlacedBy")
  orderEvents  OrderEvent[]
  journalEntries JournalEntry[]
  woNotes      WoNote[]
  quotations   Quotation[]  @relation("QuoteAgent")

  @@map("users")
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id           String   @id @default(cuid())
  code         String?  @unique
  name         String
  type         String   @default("HOSPITAL")
  tin          String?
  region       String?
  city         String?
  terms        String   @default("Net 30")
  creditLimit  Decimal  @db.Decimal(14, 2) @default(0)
  contactEmail String?
  contactPhone String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users       User[]
  orders      Order[]
  leases      Lease[]
  invoices    Invoice[]
  quotations  Quotation[]

  @@map("customers")
}

// ─── Suppliers ───────────────────────────────────────────────────────────────

enum SupplierStatus {
  ACTIVE
  ON_HOLD
  INACTIVE
}

model Supplier {
  id           String         @id @default(cuid())
  code         String?        @unique
  name         String
  contactEmail String?
  contactPhone String?
  city         String?
  terms        String         @default("Net 30")
  leadTimeDays Int            @default(7)
  rating       Decimal        @db.Decimal(3, 1) @default(4.5)
  status       SupplierStatus @default(ACTIVE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  catalogItems CatalogItem[]
  inboundPOs   InboundPO[]
  bills        Bill[]

  @@map("suppliers")
}

// ─── Catalog ─────────────────────────────────────────────────────────────────

enum ItemCategory {
  CONSUMABLE
  ACCESSORY
  EQUIPMENT
  INSTRUMENT
}

model CatalogItem {
  id         String       @id @default(cuid())
  sku        String       @unique
  name       String
  category   ItemCategory @default(CONSUMABLE)
  unit       String       @default("pc")
  unitPrice  Decimal      @db.Decimal(12, 2)
  brand      String?
  active     Boolean      @default(true)
  supplierId String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  supplier      Supplier?       @relation(fields: [supplierId], references: [id])
  orderLines    OrderLine[]
  stockRows     Stock[]
  stockMoves    StockMove[]
  inboundLines  InboundPOLine[]
  quotationLines QuotationLine[]

  @@map("catalog_items")
}

// ─── Warehouses ───────────────────────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  city      String?
  createdAt DateTime @default(now())

  orders        Order[]
  stock         Stock[]
  stockMoves    StockMove[]
  inboundPOs    InboundPO[]
  quotations    Quotation[]
  transfersFrom Transfer[] @relation("TransferFrom")
  transfersTo   Transfer[] @relation("TransferTo")

  @@map("warehouses")
}

// ─── Sales Orders ─────────────────────────────────────────────────────────────

enum OrderState {
  PENDING
  APPROVED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id          String      @id
  customerId  String
  agentId     String?
  warehouseId String
  state       OrderState  @default(PENDING)
  poRef       String?
  needBy      DateTime?
  cwt2307     Boolean     @default(false)
  subtotal    Decimal     @db.Decimal(14, 2)
  vat         Decimal     @db.Decimal(14, 2)
  cwt         Decimal     @db.Decimal(14, 2) @default(0)
  total       Decimal     @db.Decimal(14, 2)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customer    Customer    @relation(fields: [customerId],  references: [id])
  agent       User?       @relation("PlacedBy", fields: [agentId], references: [id])
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])
  lines       OrderLine[]
  events      OrderEvent[]
  shipment    Shipment?
  invoices    Invoice[]
  quotation   Quotation?

  @@map("orders")
}

model OrderLine {
  id        String  @id @default(cuid())
  orderId   String
  skuId     String
  name      String
  unit      String
  qty       Int
  unitPrice Decimal @db.Decimal(12, 2)
  lineTotal Decimal @db.Decimal(12, 2)

  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku       CatalogItem @relation(fields: [skuId],   references: [id])

  @@map("order_lines")
}

model OrderEvent {
  id        String     @id @default(cuid())
  orderId   String
  state     String
  actorId   String?
  note      String?
  createdAt DateTime   @default(now())

  order     Order      @relation(fields: [orderId],  references: [id], onDelete: Cascade)
  actor     User?      @relation(fields: [actorId],  references: [id])

  @@map("order_events")
}

// ─── Shipments ────────────────────────────────────────────────────────────────

model Shipment {
  id           String    @id @default(cuid())
  orderId      String    @unique
  trackingNumber String?
  courierId    String?
  shippedAt    DateTime?
  eta          DateTime?
  podUrl       String?
  podSignedBy  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  order        Order     @relation(fields: [orderId], references: [id])

  @@map("shipments")
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model Stock {
  id          String   @id @default(cuid())
  skuId       String
  warehouseId String
  onHand      Int      @default(0)
  reserved    Int      @default(0)
  reorderAt   Int?
  maxLevel    Int?
  updatedAt   DateTime @updatedAt

  sku         CatalogItem @relation(fields: [skuId],       references: [id])
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])

  @@unique([skuId, warehouseId])
  @@map("stock")
}

enum MoveType {
  RECEIPT
  PICK
  TRANSFER
  ADJUSTMENT
  RETURN
}

model StockMove {
  id          String   @id @default(cuid())
  skuId       String
  warehouseId String
  type        MoveType
  qty         Int
  costPerUnit Decimal  @db.Decimal(12, 2) @default(0)
  ref         String?
  note        String?
  by          String?
  at          DateTime @default(now())

  sku         CatalogItem @relation(fields: [skuId],       references: [id])
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])

  @@map("stock_moves")
}

// ─── Inbound POs ──────────────────────────────────────────────────────────────

enum InboundStatus {
  EXPECTED
  RECEIVING
  RECEIVED
  DELAYED
}

model InboundPO {
  id          String        @id
  supplierId  String
  warehouseId String
  status      InboundStatus @default(EXPECTED)
  expectedAt  DateTime
  total       Decimal       @db.Decimal(14, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  supplier    Supplier      @relation(fields: [supplierId],  references: [id])
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id])
  lines       InboundPOLine[]

  @@map("inbound_pos")
}

model InboundPOLine {
  id       String @id @default(cuid())
  poId     String
  skuId    String
  qty      Int
  accepted Int    @default(0)
  damaged  Int    @default(0)

  po       InboundPO   @relation(fields: [poId],  references: [id], onDelete: Cascade)
  sku      CatalogItem @relation(fields: [skuId], references: [id])

  @@map("inbound_po_lines")
}

// ─── Transfers ────────────────────────────────────────────────────────────────

enum TransferStatus {
  DRAFT
  IN_TRANSIT
  RECEIVED
}

model Transfer {
  id        String         @id
  fromId    String
  toId      String
  status    TransferStatus @default(DRAFT)
  eta       DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  from      Warehouse      @relation("TransferFrom", fields: [fromId], references: [id])
  to        Warehouse      @relation("TransferTo",   fields: [toId],   references: [id])
  lines     TransferLine[]

  @@map("transfers")
}

model TransferLine {
  id         String   @id @default(cuid())
  transferId String
  skuId      String
  qty        Int

  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@map("transfer_lines")
}

// ─── Equipment Leases ─────────────────────────────────────────────────────────

enum AssetCategory {
  PATIENT_MONITOR
  VENTILATOR
  INFUSION_PUMP
  OXYGEN_CONCENTRATOR
  DEFIBRILLATOR
  MONITOR
  OTHER
}

model Asset {
  id           String        @id @default(cuid())
  name         String
  serialNumber String        @unique
  category     AssetCategory @default(OTHER)
  warehouseId  String?
  purchasedAt  DateTime?
  maintenanceIntervalDays Int @default(90)
  createdAt    DateTime      @default(now())

  leaseAssets  LeaseAsset[]
  workOrders   WorkOrder[]

  @@map("assets")
}

model Lease {
  id           String   @id @default(cuid())
  customerId   String
  startDate    DateTime
  endDate      DateTime
  monthlyRate  Decimal  @db.Decimal(12, 2)
  notes        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer     Customer    @relation(fields: [customerId], references: [id])
  assets       LeaseAsset[]
  workOrders   WorkOrder[]

  @@map("leases")
}

model LeaseAsset {
  leaseId String
  assetId String

  lease   Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  asset   Asset  @relation(fields: [assetId], references: [id])

  @@id([leaseId, assetId])
  @@map("lease_assets")
}

// ─── Work Orders (PMS) ────────────────────────────────────────────────────────

enum WoStatus {
  PENDING
  IN_PROGRESS
  NEEDS_PARTS
  COMPLETED
}

enum WoPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model WorkOrder {
  id           String     @id @default(cuid())
  assetId      String
  leaseId      String?
  type         String     @default("PREVENTIVE")
  title        String
  status       WoStatus   @default(PENDING)
  priority     WoPriority @default(MEDIUM)
  technicianId String?
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  asset        Asset       @relation(fields: [assetId],      references: [id])
  lease        Lease?      @relation(fields: [leaseId],      references: [id])
  technician   Technician? @relation(fields: [technicianId], references: [id])
  notes        WoNote[]

  @@map("work_orders")
}

model WoNote {
  id          String    @id @default(cuid())
  workOrderId String
  text        String
  by          String
  userId      String?
  at          DateTime  @default(now())

  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId],      references: [id])

  @@map("wo_notes")
}

model Technician {
  id         String   @id @default(cuid())
  name       String
  specialization String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  users      User[]
  workOrders WorkOrder[]

  @@map("technicians")
}

// ─── Accounting ──────────────────────────────────────────────────────────────

enum JeSource {
  AR
  AP
  BANK
  PAYROLL
  INV
  GL
  OPENING
}

model JournalEntry {
  id         String    @id
  date       DateTime  @default(now())
  source     JeSource
  ref        String?
  memo       String
  postedById String?
  createdAt  DateTime  @default(now())

  postedBy   User?         @relation(fields: [postedById], references: [id])
  lines      JournalLine[]

  @@map("journal_entries")
}

model JournalLine {
  id    String @id @default(cuid())
  jeId  String
  code  String
  dr    Decimal @db.Decimal(14, 2) @default(0)
  cr    Decimal @db.Decimal(14, 2) @default(0)

  je    JournalEntry @relation(fields: [jeId], references: [id], onDelete: Cascade)

  @@map("journal_lines")
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PARTIAL
  OVERDUE
  PAID
}

model Invoice {
  id         String        @id
  customerId String
  soId       String?
  issued     DateTime      @default(now())
  due        DateTime
  amount     Decimal       @db.Decimal(14, 2)
  paid       Decimal       @db.Decimal(14, 2) @default(0)
  status     InvoiceStatus @default(DRAFT)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  customer   Customer      @relation(fields: [customerId], references: [id])
  order      Order?        @relation(fields: [soId],       references: [id])

  @@map("invoices")
}

enum BillStatus {
  OPEN
  DUE
  PARTIAL
  OVERDUE
  PAID
}

model Bill {
  id         String     @id
  supplierId String?
  vendor     String?
  ref        String?
  note       String?
  issued     DateTime   @default(now())
  due        DateTime
  amount     Decimal    @db.Decimal(14, 2)
  paid       Decimal    @db.Decimal(14, 2) @default(0)
  status     BillStatus @default(OPEN)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  supplier   Supplier?  @relation(fields: [supplierId], references: [id])

  @@map("bills")
}

enum BirStatus {
  DUE
  FILED
  PENDING
}

model BirFiling {
  id     String    @id
  form   String
  period String
  desc   String
  due    DateTime
  amount Decimal   @db.Decimal(14, 2) @default(0)
  status BirStatus @default(PENDING)

  @@map("bir_filings")
}

// ─── Quotations / Proforma ────────────────────────────────────────────────────

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  CONVERTED
  EXPIRED
  REJECTED
}

model Quotation {
  id          String      @id
  customerId  String
  agentId     String?
  warehouseId String
  status      QuoteStatus @default(DRAFT)
  validUntil  DateTime
  notes       String?
  subtotal    Decimal     @db.Decimal(14, 2)
  vat         Decimal     @db.Decimal(14, 2)
  cwt         Decimal     @db.Decimal(14, 2) @default(0)
  cwt2307     Boolean     @default(false)
  total       Decimal     @db.Decimal(14, 2)
  orderId     String?     @unique
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customer    Customer    @relation(fields: [customerId],   references: [id])
  agent       User?       @relation("QuoteAgent", fields: [agentId], references: [id])
  warehouse   Warehouse   @relation(fields: [warehouseId],  references: [id])
  lines       QuotationLine[]
  order       Order?      @relation(fields: [orderId],      references: [id])

  @@map("quotations")
}

model QuotationLine {
  id          String    @id @default(cuid())
  quotationId String
  skuId       String
  name        String
  unit        String
  qty         Int
  unitPrice   Decimal   @db.Decimal(12, 2)
  lineTotal   Decimal   @db.Decimal(12, 2)

  quotation   Quotation   @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  sku         CatalogItem @relation(fields: [skuId],       references: [id])

  @@map("quotation_lines")
}
