generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  AGENT
  FINANCE
  WAREHOUSE
  TECHNICIAN
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          Role      @default(AGENT)
  customerId    String?   // set when role = CUSTOMER
  technicianId  String?   // set when role = TECHNICIAN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customer      Customer?    @relation(fields: [customerId], references: [id])
  technician    Technician?  @relation(fields: [technicianId], references: [id])
  ordersPlaced  Order[]      @relation("PlacedBy")
  woNotes       WoNote[]

  @@map("users")
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id          String   @id @default(cuid())
  code        String   @unique  // e.g. C-1042
  name        String
  contact     String
  region      String
  city        String
  terms       String   @default("Net 30")
  creditLimit Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  orders      Order[]
  leases      Lease[]

  @@map("customers")
}

// ─── Suppliers ───────────────────────────────────────────────────────────────

enum SupplierStatus {
  ACTIVE
  PROBATION
  SUSPENDED
}

model Supplier {
  id          String         @id @default(cuid())
  code        String         @unique  // e.g. SUP-101
  name        String
  contact     String
  city        String
  terms       String         @default("Net 30")
  leadDays    Int            @default(7)
  rating      Decimal        @db.Decimal(3, 1) @default(4.5)
  status      SupplierStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  catalogItems CatalogItem[]
  inboundPOs   InboundPO[]

  @@map("suppliers")
}

// ─── Catalog ─────────────────────────────────────────────────────────────────

enum ItemCategory {
  CONSUMABLE
  ACCESSORY
  EQUIPMENT
}

model CatalogItem {
  sku        String       @id
  name       String
  category   ItemCategory @default(CONSUMABLE)
  unit       String       @default("pc")
  price      Decimal      @db.Decimal(12, 2)
  active     Boolean      @default(true)
  supplierId String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  supplier   Supplier?    @relation(fields: [supplierId], references: [id])
  orderLines OrderLine[]
  stockRows  Stock[]
  stockMoves StockMove[]
  inboundLines InboundPOLine[]

  @@map("catalog_items")
}

// ─── Warehouses ───────────────────────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique  // MNL, CEB, DVO
  name      String
  createdAt DateTime @default(now())

  orders     Order[]
  stock      Stock[]
  stockMoves StockMove[]
  inboundPOs InboundPO[]
  transfersFrom Transfer[] @relation("TransferFrom")
  transfersTo   Transfer[] @relation("TransferTo")

  @@map("warehouses")
}

// ─── Sales Orders ─────────────────────────────────────────────────────────────

enum OrderState {
  PENDING
  APPROVED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id          String     @id  // SO-2026-XXXX
  customerId  String
  agentId     String?    // User.id
  warehouseId String
  state       OrderState @default(PENDING)
  poRef       String?
  needBy      DateTime
  cwt2307     Boolean    @default(false)
  subtotal    Decimal    @db.Decimal(14, 2)
  vat         Decimal    @db.Decimal(14, 2)
  cwt         Decimal    @db.Decimal(14, 2) @default(0)
  total       Decimal    @db.Decimal(14, 2)
  pickProgress Decimal?  @db.Decimal(4, 3)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  customer    Customer   @relation(fields: [customerId], references: [id])
  agent       User?      @relation("PlacedBy", fields: [agentId], references: [id])
  warehouse   Warehouse  @relation(fields: [warehouseId], references: [id])
  lines       OrderLine[]
  events      OrderEvent[]
  shipment    Shipment?

  @@map("orders")
}

model OrderLine {
  id        String  @id @default(cuid())
  orderId   String
  sku       String
  name      String
  unit      String
  qty       Int
  unitPrice Decimal @db.Decimal(12, 2)

  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item      CatalogItem @relation(fields: [sku], references: [sku])

  @@map("order_lines")
}

model OrderEvent {
  id      String     @id @default(cuid())
  orderId String
  state   String
  at      DateTime   @default(now())
  by      String?
  note    String?

  order   Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_events")
}

// ─── Shipments ────────────────────────────────────────────────────────────────

enum CourierId {
  JRS
  LBC
  JNT
  TWO_GO
  OWN_FLEET
}

model Shipment {
  id          String    @id @default(cuid())
  orderId     String    @unique
  waybill     String?
  courier     CourierId @default(OWN_FLEET)
  dispatchedAt DateTime?
  deliveredAt  DateTime?
  podFileUrl  String?
  podSignedBy String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  order       Order     @relation(fields: [orderId], references: [id])

  @@map("shipments")
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model Stock {
  id          String   @id @default(cuid())
  sku         String
  warehouseId String
  onHand      Int      @default(0)
  reserved    Int      @default(0)
  reorderPt   Int      @default(0)
  maxLevel    Int      @default(0)
  updatedAt   DateTime @updatedAt

  item        CatalogItem @relation(fields: [sku], references: [sku])
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])

  @@unique([sku, warehouseId])
  @@map("stock")
}

enum MoveType {
  RECEIPT
  PICK
  TRANSFER
  ADJUSTMENT
  RETURN
}

model StockMove {
  id          String   @id @default(cuid())
  sku         String
  warehouseId String
  type        MoveType
  qty         Int
  costPerUnit Decimal  @db.Decimal(12, 2) @default(0)
  ref         String?
  note        String?
  by          String?
  at          DateTime @default(now())

  item        CatalogItem @relation(fields: [sku], references: [sku])
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])

  @@map("stock_moves")
}

// ─── Inbound POs ──────────────────────────────────────────────────────────────

enum InboundStatus {
  EXPECTED
  RECEIVING
  RECEIVED
  DELAYED
}

model InboundPO {
  id          String        @id  // PO-2026-XXXX
  supplierId  String
  warehouseId String
  status      InboundStatus @default(EXPECTED)
  expectedAt  DateTime
  total       Decimal       @db.Decimal(14, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  supplier    Supplier      @relation(fields: [supplierId], references: [id])
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id])
  lines       InboundPOLine[]

  @@map("inbound_pos")
}

model InboundPOLine {
  id       String @id @default(cuid())
  poId     String
  sku      String
  qty      Int
  accepted Int    @default(0)
  damaged  Int    @default(0)

  po       InboundPO   @relation(fields: [poId], references: [id], onDelete: Cascade)
  item     CatalogItem @relation(fields: [sku], references: [sku])

  @@map("inbound_po_lines")
}

// ─── Transfers ────────────────────────────────────────────────────────────────

enum TransferStatus {
  DRAFT
  IN_TRANSIT
  RECEIVED
}

model Transfer {
  id          String         @id  // TR-XXXX
  fromId      String
  toId        String
  status      TransferStatus @default(DRAFT)
  eta         DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  from        Warehouse      @relation("TransferFrom", fields: [fromId], references: [id])
  to          Warehouse      @relation("TransferTo",   fields: [toId],   references: [id])
  lines       TransferLine[]

  @@map("transfers")
}

model TransferLine {
  id         String   @id @default(cuid())
  transferId String
  sku        String
  qty        Int

  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@map("transfer_lines")
}

// ─── Equipment Leases ─────────────────────────────────────────────────────────

enum AssetCategory {
  PATIENT_MONITOR
  VENTILATOR
  INFUSION_PUMP
  OXYGEN_CONCENTRATOR
  DEFIBRILLATOR
  OTHER
}

model Asset {
  id            String        @id  // AST-XXXX
  model         String
  serial        String        @unique
  category      AssetCategory @default(OTHER)
  commissioned  DateTime
  createdAt     DateTime      @default(now())

  leaseAssets   LeaseAsset[]
  workOrders    WorkOrder[]

  @@map("assets")
}

model Lease {
  id                String   @id  // LSE-2026-XXX
  customerId        String
  contractRef       String
  startDate         DateTime
  termMonths        Int
  monthlyFee        Decimal  @db.Decimal(12, 2)
  maintenanceMonths Int      @default(3)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer          Customer    @relation(fields: [customerId], references: [id])
  assets            LeaseAsset[]
  workOrders        WorkOrder[]

  @@map("leases")
}

model LeaseAsset {
  leaseId String
  assetId String

  lease   Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  asset   Asset  @relation(fields: [assetId], references: [id])

  @@id([leaseId, assetId])
  @@map("lease_assets")
}

// ─── Work Orders (PMS) ────────────────────────────────────────────────────────

enum WoStatus {
  PENDING
  IN_PROGRESS
  NEEDS_PARTS
  COMPLETED
}

enum WoPriority {
  NORMAL
  URGENT
}

model WorkOrder {
  id           String     @id  // WO-2026-XXXX
  leaseId      String
  assetId      String
  customerId   String
  scheduledFor DateTime
  status       WoStatus   @default(PENDING)
  priority     WoPriority @default(NORMAL)
  taskDetails  String
  technicianId String?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  lease        Lease      @relation(fields: [leaseId], references: [id])
  asset        Asset      @relation(fields: [assetId], references: [id])
  technician   Technician? @relation(fields: [technicianId], references: [id])
  notes        WoNote[]

  @@map("work_orders")
}

model WoNote {
  id          String    @id @default(cuid())
  workOrderId String
  by          String
  text        String
  at          DateTime  @default(now())
  userId      String?

  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id])

  @@map("wo_notes")
}

model Technician {
  id        String   @id  // T-01, T-02…
  name      String
  region    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  users      User[]
  workOrders WorkOrder[]

  @@map("technicians")
}
